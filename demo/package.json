{
  "name": "demo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:*",
    "dev:server": "node --watch node_modules/vexjs/server/index.js",
    "dev:css": "npx @tailwindcss/cli -i ./src/input.css -o ./public/styles.css --watch",
    "build": "node node_modules/vexjs/server/prebuild.js",
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./public/styles.css --minify",
    "start": "NODE_ENV=production node node_modules/vexjs/server/index.js"
  },
  "dependencies": {
    "vexjs": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "tailwindcss": "^4.1.17",
    "npm-run-all": "^4.1.5"
  }
}
